{#
/**
 * @file
 * Business "Website" link field — render a friendly "Visit website" button
 * instead of the raw URL as link text. Used on the business detail page
 * (the /businesses teaser renders its own link in node--business--teaser).
 */
#}
{% for item in items %}
  <div{{ item.attributes.addClass('field__item') }}>
    <a href="{{ item.content['#url'] }}" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm">{{ 'Visit website'|t }}</a>
  </div>
{% endfor %}
