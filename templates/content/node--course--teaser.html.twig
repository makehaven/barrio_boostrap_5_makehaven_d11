{#
/**
 * @file
 * Teaser template for Course nodes — used by the public catalog at
 * /workshops. Mirrors the event-card DOM (.card / .card-img-top /
 * .card-body / .card-title / .card-text) so the catalog inherits the same
 * visual treatment as /events.
 *
 * Variables provided by barrio_boostrap_5_makehaven_d11_preprocess_node__course__teaser():
 *  - workshop_upcoming_count: Number of scheduled future instances.
 *  - workshop_runs_count: Total historical runs.
 *  - attributes adds 'course-teaser--member-only' on badge_class courses.
 */
#}
<article{{ attributes.addClass('node', 'node--type-course', 'node--view-mode-teaser', 'card') }}>

  {% if content.field_course_image|render %}
    <div class="card-img-top">
      {{ content.field_course_image }}
    </div>
  {% endif %}

  <div class="card-body">
    <h3{{ title_attributes.addClass('card-title') }}>
      <a href="{{ url }}">{{ label }}</a>
    </h3>

    <div class="card-text">
      <div class="course-stat-chips">
        {% if workshop_upcoming_count > 0 %}
          <time class="course-stat-chip course-stat-chip--upcoming">
            {{ workshop_upcoming_count }}
            {{ workshop_upcoming_count == 1 ? 'upcoming session'|t : 'upcoming sessions'|t }}
          </time>
        {% endif %}

        {% if workshop_runs_count > 0 %}
          <span class="course-stat-chip course-stat-chip--runs">
            {{ workshop_runs_count == 1 ? 'Run 1 time'|t : 'Run @count times'|t({'@count': workshop_runs_count}) }}
          </span>
        {% endif %}
      </div>

      {% if content.field_course_badges|render %}
        <div class="course-badges">
          <span class="course-badges__label">{{ 'Earn:'|t }}</span>
          {{ content.field_course_badges }}
        </div>
      {% endif %}

      {% if content.body|render %}
        <div class="summary">
          {{ content.body }}
        </div>
      {% endif %}

      <a href="{{ url }}" class="btn btn-primary">{{ 'View workshop'|t }} →</a>
    </div>
  </div>

</article>
